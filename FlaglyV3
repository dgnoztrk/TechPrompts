    var env = HttpContext.Items["Environment"] as ProjectEnvironment;
    cacheKey = $"flagly:flags:{env.ProjectId}:{env.ApiKey}";
    cached = await _cache.GetFlagsAsync(cacheKey);
    if (cached != null) return cached;
    
    flags = await _uow.FeatureFlags.GetByProjectIdAsync(env.ProjectId);
