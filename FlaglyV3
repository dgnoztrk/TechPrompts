## FLAG EVALUATION LOGIC
═══════════════════════════════════════════════════════════════

Flagly.Domain/Evaluation/FlagEvaluator.cs — pure static logic, no DI, no DB

bool Evaluate(
    FeatureFlagEnvironmentState state,
    FlaglyContext context,
    IReadOnlyList<GroupMemberDto>? resolvedUserGroupMembers = null,
    IReadOnlyList<CompanyMemberDto>? resolvedCompanyMembers = null)

STEP 1: if (!state.IsEnabled) → return false

STEP 2: switch (state.TargetMode)

  case Everyone:
    return true

  case SpecificUsers:
    if (string.IsNullOrWhiteSpace(state.TargetUserList)) return true
    var list = state.TargetUserList
      .Split(',', StringSplitOptions.RemoveEmptyEntries)
      .Select(x => x.Trim())
      .ToHashSet(StringComparer.OrdinalIgnoreCase);
    return state.TargetIdentifierType == IdentifierType.UserId
      ? context.UserId != null && list.Contains(context.UserId)
      : context.UserEmail != null && list.Contains(context.UserEmail);

  case UserGroup:
    if (resolvedUserGroupMembers == null || !resolvedUserGroupMembers.Any())
      return false
    return resolvedUserGroupMembers.Any(m =>
      (m.Type == IdentifierType.UserId
        && string.Equals(m.Identifier, context.UserId, OrdinalIgnoreCase))
      ||
      (m.Type == IdentifierType.Email
        && string.Equals(m.Identifier, context.UserEmail, OrdinalIgnoreCase)));

  case Company:
    if (resolvedCompanyMembers == null || !resolvedCompanyMembers.Any())
      return false
    // Company override: if the calling context's company identifier
    // matches ANY member in the company group → flag is ON.
    // This is company-level, user-independent: who the user is doesn't matter.
    return resolvedCompanyMembers.Any(m =>
      (m.Type == CompanyIdentifierType.Vkn
        && !string.IsNullOrEmpty(context.CompanyVkn)
        && string.Equals(m.Identifier, context.CompanyVkn, OrdinalIgnoreCase))
      ||
      (m.Type == CompanyIdentifierType.Tckn
        && !string.IsNullOrEmpty(context.CompanyTckn)
        && string.Equals(m.Identifier, context.CompanyTckn, OrdinalIgnoreCase)));

  default: return false

TargetMode values are MUTUALLY EXCLUSIVE. No priority chain.
Each flag state has exactly one TargetMode set. The evaluator switches on it.

