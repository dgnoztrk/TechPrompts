## EVALUATION LOGIC
═══════════════════════════════════════════════════════════════

Flagly.Core/Evaluation/FlagEvaluator.cs — stateless, no DB access

bool Evaluate(
    FeatureFlagEnvironmentState state,
    FlaglyContext context,
    IReadOnlyList<GroupMemberDto>? resolvedGroupMembers = null)

1. if (!state.IsEnabled) → return false

2. switch (state.TargetMode):

   Everyone:
     return true

   SpecificUsers:
     if (string.IsNullOrWhiteSpace(state.TargetUserList)) return true
     var list = state.TargetUserList
       .Split(',', StringSplitOptions.RemoveEmptyEntries)
       .Select(x => x.Trim())
       .ToHashSet(StringComparer.OrdinalIgnoreCase);
     return state.TargetIdentifierType == IdentifierType.UserId
       ? context.UserId != null && list.Contains(context.UserId)
       : context.UserEmail != null && list.Contains(context.UserEmail);

   UserGroup:
     if (resolvedGroupMembers == null || !resolvedGroupMembers.Any())
       return false
     return resolvedGroupMembers.Any(m =>
       (m.Type == IdentifierType.UserId
         && string.Equals(m.Identifier, context.UserId,
              StringComparison.OrdinalIgnoreCase))
       ||
       (m.Type == IdentifierType.Email
         && string.Equals(m.Identifier, context.UserEmail,
              StringComparison.OrdinalIgnoreCase)));

Service layer loads GroupMembers from DB before calling Evaluate().
GroupMembers are also included in SDK API response so SDK evaluates client-side.

