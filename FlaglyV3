  // Client-side validation
  if (!identifier) {
    showInputError(identifierInput, 'Identifier is required');
    return;
  }
  if (identifierType === 1 && !isValidEmail(identifier)) {
    showInputError(identifierInput, 'Enter a valid email address');
    return;
  }
  clearInputError(identifierInput);
  
  const addBtn = document.getElementById('addMemberBtn');
  addBtn.disabled = true;
  addBtn.textContent = 'Adding...';
  
  const { ok, status, data } = await apiCall(
    `/projects/${projectSlug}/groups/${selectedGroupId}/members`,
    'POST',
    { identifier, identifierType }
  );
  
  addBtn.disabled = false;
  addBtn.textContent = '+ Add Member';
  
  if (!ok) {
    if (status === 409) {
      showInputError(identifierInput, 'Already in group');
    } else {
      showToast(data.error ?? 'Failed to add member', 'error');
    }
    return;
  }
  
  // Remove empty state row if present
  document.getElementById('emptyMembersRow')?.remove();
  
  // Append new row to table
  const tbody = document.getElementById('memberTableBody');
  const newRow = document.createElement('tr');
  newRow.setAttribute('data-member-id', data.member.id);
  newRow.style.opacity = '0';
  newRow.innerHTML = memberRowHtml(data.member).replace('<tr', '<tr').split('\n').slice(1,-1).join('\n');
  // Actually: just re-render entire table via loadGroupMembers for simplicity
  // but to avoid full reload, insert row:
  tbody.insertAdjacentHTML('beforeend', memberRowHtml(data.member));
  
  // Attach handler to new row's remove button
  const newRemoveBtn = tbody.querySelector(`[data-member-id="${data.member.id}"].remove-member-btn`);
  newRemoveBtn?.addEventListener('click', () => removeMember(data.member.id));
  
  // Animate in
  requestAnimationFrame(() => {
    const newTr = tbody.querySelector(`tr[data-member-id="${data.member.id}"]`);
    if (newTr) { newTr.style.opacity = '0'; requestAnimationFrame(() => newTr.style.opacity = '1'); }
  });
  
  // Update counts
  updateMemberCount(selectedGroupId, tbody.querySelectorAll('tr:not(#emptyMembersRow)').length);
  
  // Clear input, flash success
  identifierInput.value = '';
  identifierInput.style.borderColor = 'var(--success)';
  setTimeout(() => identifierInput.style.borderColor = '', 1000);
}

async function removeMember(memberId) {
  const projectSlug = document.getElementById('groupsTab').dataset.projectSlug;
  const row = document.querySelector(`tr[data-member-id="${memberId}"]`);
  if (!row) return;
  
  // Optimistic: fade out row
  row.style.opacity = '0.4';
  
  const { ok, data } = await apiCall(
    `/projects/${projectSlug}/groups/${selectedGroupId}/members/${memberId}`,
    'DELETE'
  );
  
  if (!ok) {
    row.style.opacity = '1';
    showToast('Failed to remove member', 'error');
    return;
  }
  
  row.remove();
  
  const tbody = document.getElementById('memberTableBody');
  if (tbody.querySelectorAll('tr').length === 0) {
    renderMemberTable([]); // show empty state
  }
  
  const remaining = tbody.querySelectorAll('tr:not(#emptyMembersRow)').length;
  updateMemberCount(selectedGroupId, remaining);
}

function updateMemberCount(groupId, count) {
  // Update member count badge in left panel card for this groupId
  const card = document.querySelector(`.group-card[data-group-id="${groupId}"]`);
  const badge = card?.querySelector('.member-count-badge');
  if (badge) badge.textContent = `${count} members`;
  // Update right panel header count
  const header = document.getElementById('memberCountHeader');
  if (header) header.textContent = `Members (${count})`;
}

function showInputError(input, message) {
  input.style.borderColor = 'var(--danger)';
  let errEl = input.parentElement.querySelector('.input-error');
  if (!errEl) {
    errEl = document.createElement('div');
    errEl.className = 'input-error';
    errEl.style.cssText = 'color:var(--danger);font-size:12px;margin-top:4px';
    input.parentElement.appendChild(errEl);
  }
  errEl.textContent = message;
}

function clearInputError(input) {
  input.style.borderColor = '';
  input.parentElement.querySelector('.input-error')?.remove();
}

function isValidEmail(str) {
  return /^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(str);
}

function escapeHtml(str) {
  return str.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');
}

// ── TIME AGO ─────────────────────────────────────────────────

function formatTimeAgo(date) {
  const seconds = Math.floor((new Date() - date) / 1000);
  if (seconds < 60) return 'just now';
  if (seconds < 3600) return `${Math.floor(seconds/60)} minutes ago`;
  if (seconds < 86400) return `${Math.floor(seconds/3600)} hours ago`;
  if (seconds < 604800) return `${Math.floor(seconds/86400)} days ago`;
  return date.toLocaleDateString();
}

